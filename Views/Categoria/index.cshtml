@model List<TiendaVirtualReyes.Models.Categoria>

<h2>Lista de categoria</h2>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nombre</th>
            <th>Descripcion</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Nombre</td>
                <td>@item.Descripcion</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.Nombre))
                    {
                        <span class="text-success">activo</span>
                    }
                    else
                    {
                        <span class="text-danger">sin nombre</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>